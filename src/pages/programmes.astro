---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SectionBand from '../components/SectionBand.astro';
import CtaButton from '../components/CtaButton.astro';

const highlights = [
  {
    icon: 'lucide:baby',
    title: 'Age-appropriate',
    text: 'Every activity is matched to your child’s stage — challenging enough to grow, gentle enough to enjoy.',
  },
  {
    icon: 'lucide:puzzle',
    title: 'Learning through play',
    text: 'Hands-on, playful experiences that make discovery feel like fun, never like work.',
  },
  {
    icon: 'lucide:heart',
    title: 'The whole child',
    text: 'We nurture intellect, body and emotions together — happy, healthy, well-rounded little people.',
  },
  {
    icon: 'lucide:trees',
    title: 'Beyond the classroom',
    text: 'Learning spills into gardens, play areas and outings, so curiosity has room to roam.',
  },
];
---

<BaseLayout
  title="Programmes"
  description="Toddler World's Montessori-inspired programme for children aged 2–3 is crafted around each child's developmental stage — nurturing them intellectually, physically and emotionally."
>
  <PageHero eyebrow="Learning through play" title="Our Programmes" accent="grape">
    <p>Thoughtfully crafted around your child's age, ability and boundless curiosity.</p>
  </PageHero>

  <section class="section container">
    <div class="prog-intro prose" data-reveal>
      <p class="lead">
        Our programmes are designed with your child's age and natural pace of learning in mind. We
        give every child the chance to challenge themselves, while paying just as much attention to
        keeping them fit, active and joyful. And because the best learning isn't confined to a
        classroom, our days are full of variety that makes it all feel like fun.
      </p>
    </div>

    <article class="prog-feature" data-reveal>
      <div class="prog-feature__media">
        <img
          src="/images/programmes/2.webp"
          alt="Pre-nursery children developing foundational skills"
          width="720"
          height="560"
          loading="lazy"
        />
      </div>
      <div class="prog-feature__body">
        <span class="prog-feature__tag">Ages 2–3 years</span>
        <h2>Pre-Nursery</h2>
        <p>
          A strong foundation for success in school and in life. Our Pre-Nursery programme nurtures
          your child across six pillars — Citizen, Scholar, Mind, Body, Milestones and Assessment —
          so they step into their next classroom ready, confident and eager to learn.
        </p>
        <CtaButton variant="grape" href="/pre-nursery">Explore Pre-Nursery</CtaButton>
      </div>
    </article>
  </section>

  <SectionBand bg="grape" waveTop>
    <div class="container">
      <SectionHeader eyebrow="What makes it special" title="Tailored to your child's stage" />
      <div class="highlight-grid">
        {
          highlights.map((h) => (
            <div class="highlight" data-reveal>
              <span class="highlight__icon">
                <Icon name={h.icon} />
              </span>
              <h3>{h.title}</h3>
              <p>{h.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </SectionBand>
</BaseLayout>

<style>
  .prog-intro {
    max-width: 52rem;
    margin-inline: auto;
    text-align: center;
    margin-bottom: var(--sp-8);
  }

  .prog-feature {
    display: grid;
    gap: 0;
    background: var(--c-white);
    border: 2px solid var(--c-line);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  @media (min-width: 820px) {
    .prog-feature {
      grid-template-columns: 1fr 1fr;
    }
  }
  .prog-feature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 300px;
  }
  .prog-feature__body {
    padding: clamp(var(--sp-5), 4vw, var(--sp-7));
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-3);
    justify-content: center;
  }
  .prog-feature__tag {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
    color: var(--c-grape);
    background: var(--c-grape-bg);
    padding: 0.3em 0.9em;
    border-radius: var(--radius-pill);
  }
  .prog-feature__body p {
    color: var(--c-ink-soft);
    font-size: var(--fs-500);
  }

  .highlight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr));
    gap: var(--sp-5);
  }
  .highlight {
    background: var(--c-white);
    border: 2px solid #e6d8f7;
    border-radius: var(--radius-lg);
    padding: var(--sp-5);
    box-shadow: var(--shadow-sm);
  }
  .highlight__icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--c-grape-bg);
    color: var(--c-grape);
    margin-bottom: var(--sp-3);
  }
  .highlight__icon :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
  }
  .highlight h3 {
    color: var(--c-ink);
    font-size: var(--fs-600);
    margin-bottom: var(--sp-2);
  }
  .highlight p {
    color: var(--c-ink-soft);
    font-size: var(--fs-body);
  }
</style>
