---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CardGrid from '../components/CardGrid.astro';
import Card from '../components/Card.astro';
import SectionBand from '../components/SectionBand.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CtaButton from '../components/CtaButton.astro';

const cards = [
  {
    title: 'Our Team',
    href: '/our-team',
    image: '/images/about/first.webp',
    alt: 'A group of happy children at Toddler World',
    accent: 'coral' as const,
    eyebrow: 'The people',
    text: 'Meet the warm, dedicated educators who bring learning to life with patience and heart.',
  },
  {
    title: 'Our Environment',
    href: '/our-environment',
    image: '/images/about/second.webp',
    alt: 'A child playing on the alphabet rug in our bright playroom',
    accent: 'green' as const,
    eyebrow: 'The place',
    text: 'Explore the safe, calm, nurturing spaces we’ve designed for discovery and growth.',
  },
  {
    title: 'Our Activities',
    href: '/activities',
    image: '/images/about/third.webp',
    alt: 'A smiling girl showing off her red and yellow painted hands',
    accent: 'grape' as const,
    eyebrow: 'The play',
    text: 'Discover the joyful, hands-on activities that make every day fun and memorable.',
  },
];
---

<BaseLayout
  title="About Us"
  description="Discover Toddler World: our caring team, our nurturing environment and the joyful activities that make our Srinagar preschool special."
>
  <PageHero eyebrow="Who we are" title="About Toddler World" accent="green">
    <p>A family-built preschool where little ones aged 2–3 feel safe, seen and full of wonder.</p>
  </PageHero>

  <section class="section container">
    <div class="about-intro prose" data-reveal>
      <p class="lead">
        Toddler World was created by a family who wanted to bring the very best of early childhood
        care to Kashmir, combining world-class methods with the warmth of home. Everything we do is
        built around one simple belief: happy children learn best.
      </p>
    </div>
  </section>

  <SectionBand bg="cream2" waveTop>
    <div class="container">
      <SectionHeader eyebrow="Get to know us" title="Three ways to explore Toddler World" />
      <CardGrid>
        {
          cards.map((c) => (
            <div data-reveal>
              <Card
                title={c.title}
                href={c.href}
                image={c.image}
                alt={c.alt}
                accent={c.accent}
                eyebrow={c.eyebrow}
              >
                {c.text}
              </Card>
            </div>
          ))
        }
      </CardGrid>
      <div class="about-cta" data-reveal>
        <CtaButton href="/welcome">Read our welcome note</CtaButton>
      </div>
    </div>
  </SectionBand>
</BaseLayout>

<style>
  .about-intro {
    max-width: 52rem;
    margin-inline: auto;
    text-align: center;
  }
  .about-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--sp-7);
  }
</style>
