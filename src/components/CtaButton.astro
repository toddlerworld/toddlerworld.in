---
interface Props {
  href?: string;
  variant?: 'primary' | 'sunny' | 'ghost' | 'whatsapp' | 'sky' | 'grape' | 'coral';
  size?: 'md' | 'lg';
  external?: boolean;
  type?: 'button' | 'submit';
  class?: string;
  id?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  type = 'button',
  class: className = '',
  id,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<Tag
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  href={href}
  target={target}
  rel={rel}
  type={href ? undefined : type}
  id={id}
>
  <span class="btn__label"><slot /></span>
</Tag>

<style>
  .btn {
    --btn-bg: var(--c-secondary);
    --btn-ink: var(--c-secondary-ink);
    --btn-shadow: var(--shadow-play);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    text-decoration: none;
    line-height: 1;
    color: var(--btn-ink);
    background: var(--btn-bg);
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.85em 1.6em;
    min-height: 48px;
    cursor: pointer;
    box-shadow: var(--btn-shadow);
    transition:
      transform var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  .btn--lg {
    font-size: var(--fs-500);
    padding: 1em 2em;
    min-height: 56px;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-play), var(--shadow-md);
    color: var(--btn-ink);
  }

  .btn:active {
    transform: translateY(3px);
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.14);
  }

  /* Variants */
  .btn--primary {
    --btn-bg: var(--c-secondary);
    --btn-ink: var(--c-secondary-ink);
  }
  .btn--primary:hover {
    --btn-bg: var(--c-secondary-strong);
  }

  .btn--sunny {
    --btn-bg: var(--c-primary);
    --btn-ink: var(--c-primary-ink);
  }
  .btn--sunny:hover {
    --btn-bg: var(--c-primary-strong);
  }

  .btn--whatsapp {
    --btn-bg: var(--c-whatsapp);
    --btn-ink: #04331a;
  }

  .btn--sky {
    --btn-bg: var(--c-sky);
    --btn-ink: #06263a;
  }
  .btn--grape {
    --btn-bg: var(--c-grape);
    --btn-ink: #ffffff;
  }
  .btn--coral {
    --btn-bg: var(--c-coral);
    --btn-ink: #ffffff;
  }

  .btn--ghost {
    --btn-bg: transparent;
    --btn-ink: var(--c-ink);
    box-shadow: inset 0 0 0 2.5px var(--c-ink);
  }
  .btn--ghost:hover {
    --btn-bg: var(--c-ink);
    --btn-ink: var(--c-cream);
    box-shadow:
      inset 0 0 0 2.5px var(--c-ink),
      var(--shadow-md);
  }
  .btn--ghost:active {
    box-shadow: inset 0 0 0 2.5px var(--c-ink);
  }
</style>
