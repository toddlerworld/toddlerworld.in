---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import MapEmbed from '../components/MapEmbed.astro';
import OpeningHours from '../components/islands/OpeningHours.tsx';
import { site } from '../data/site';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Toddler World, Srinagar. Call us, message on WhatsApp, drop us a line, or visit us at Airport Avenue, Near Railway Bridge."
>
  <PageHero eyebrow="We'd love to hear from you" title="Contact Us" accent="green">
    <p>Questions, visits, enrolments: we're always happy to help.</p>
  </PageHero>

  <section class="section container">
    <div class="contact-layout">
      <!-- Form -->
      <div class="contact-form-wrap" data-reveal>
        <h2>Drop us a line</h2>
        <p class="contact-form-intro">
          Send us a message and we'll get back to you as soon as we can.
        </p>
        <form
          class="contact-form"
          action={site.integrations.contactForm}
          method="POST"
          data-contact-form
        >
          <label class="field">
            <span>Your name</span>
            <input type="text" name="name" placeholder="e.g. Ayesha Khan" required />
          </label>
          <label class="field">
            <span>Email address</span>
            <input type="email" name="email" placeholder="you@example.com" required />
          </label>
          <label class="field">
            <span>Message</span>
            <textarea name="message" rows="6" placeholder="How can we help?" required></textarea>
          </label>
          <button type="submit" class="contact-submit">Send message</button>
          <p class="contact-status" data-form-status role="status" aria-live="polite"></p>
        </form>
        <p class="contact-captcha">
          By sending this message you agree to be contacted by Toddler World. We'll only ever use
          your details to reply to you.
        </p>
      </div>

      <!-- Details -->
      <div class="contact-details" data-reveal>
        <h2>Better yet, see us in person</h2>
        <p>Feel free to call to book an appointment. We'd love to show you around.</p>

        <a
          class="whatsapp-btn"
          href={site.integrations.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:whatsapp" />
          Message us on WhatsApp
        </a>

        <ul class="detail-list">
          <li>
            <span class="detail-icon"><Icon name="lucide:map-pin" /></span>
            <div>
              <h3>Visit us</h3>
              <p>{site.address.full}</p>
            </div>
          </li>
          <li>
            <span class="detail-icon"><Icon name="lucide:phone" /></span>
            <div>
              <h3>Call us</h3>
              {
                site.phones.map((p) => (
                  <p>
                    <a href={p.href}>{p.label}</a>
                  </p>
                ))
              }
            </div>
          </li>
          <li>
            <span class="detail-icon"><Icon name="lucide:mail" /></span>
            <div>
              <h3>Email us</h3>
              <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
            </div>
          </li>
          <li>
            <span class="detail-icon"><Icon name="lucide:clock" /></span>
            <div class="detail-hours">
              <h3>Opening hours</h3>
              <OpeningHours client:idle hours={site.hours} />
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="container contact-map-section">
    <MapEmbed />
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    gap: var(--sp-7);
    align-items: start;
  }
  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .contact-form-wrap h2 {
    margin-bottom: var(--sp-2);
  }
  .contact-form-intro {
    color: var(--c-ink-soft);
    margin-bottom: var(--sp-5);
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .field span {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 0.85em 1em;
    border: 2px solid var(--c-line);
    border-radius: var(--radius-md);
    background: var(--c-white);
    font-family: var(--font-body);
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .field input:focus,
  .field textarea:focus {
    border-color: var(--c-secondary);
    outline: none;
  }
  .field textarea {
    resize: vertical;
  }
  .contact-submit {
    align-self: flex-start;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    color: var(--c-secondary-ink);
    background: var(--c-secondary);
    border: none;
    border-radius: var(--radius-pill);
    padding: 0.85em 2em;
    min-height: 52px;
    cursor: pointer;
    box-shadow: var(--shadow-play);
    transition:
      transform var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .contact-submit:hover {
    transform: translateY(-2px);
    background: var(--c-secondary-strong);
  }
  .contact-submit:active {
    transform: translateY(3px);
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.14);
  }
  .contact-submit:disabled {
    opacity: 0.7;
    cursor: default;
  }
  .contact-status {
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
  }
  .contact-status.is-success {
    color: var(--c-secondary-strong);
  }
  .contact-status.is-error {
    color: var(--c-error);
  }
  .contact-captcha {
    margin-top: var(--sp-4);
    font-size: var(--fs-xs);
    color: var(--c-ink-faint);
  }

  /* Details */
  .contact-details > p {
    color: var(--c-ink-soft);
    margin-top: var(--sp-2);
  }
  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    margin-top: var(--sp-4);
    background: var(--c-whatsapp);
    color: #04331a;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    padding: 0.75em 1.3em;
    border-radius: var(--radius-pill);
    text-decoration: none;
    box-shadow: var(--shadow-play);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .whatsapp-btn:hover {
    transform: translateY(-2px);
    color: #04331a;
  }
  .whatsapp-btn :global(svg) {
    width: 1.3em;
    height: 1.3em;
  }

  .detail-list {
    list-style: none;
    padding: 0;
    margin-top: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }
  .detail-list li {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
  }
  .detail-icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: var(--radius-md);
    background: var(--c-mint-bg);
    color: var(--c-secondary-strong);
  }
  .detail-icon :global(svg) {
    width: 1.3rem;
    height: 1.3rem;
  }
  .detail-list h3 {
    font-size: var(--fs-600);
    margin-bottom: var(--sp-1);
  }
  .detail-list p {
    color: var(--c-ink-soft);
  }
  .detail-hours {
    flex: 1;
    min-width: 0;
  }

  .contact-map-section {
    padding-bottom: var(--section-y);
  }
  .contact-map-section :global(.map) {
    min-height: 440px;
  }
</style>

<script>
  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!status || !button) return;
      button.disabled = true;
      status.className = 'contact-status';
      status.textContent = 'Sending…';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          status.className = 'contact-status is-success';
          status.textContent = 'Thank you! Your message is on its way. We’ll be in touch soon.';
        } else {
          throw new Error('Bad response');
        }
      } catch {
        status.className = 'contact-status is-error';
        status.textContent =
          'Sorry, something went wrong. Please email toddlerworld.sgr@gmail.com or call us instead.';
      } finally {
        button.disabled = false;
      }
    });
  }
  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
