---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'center' | 'start';
  class?: string;
}
const { eyebrow, title, align = 'center', class: className = '' } = Astro.props;
---

<header class:list={['section-header', `section-header--${align}`, className]} data-reveal>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>{title}</h2>
  <slot />
</header>

<style>
  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-bottom: var(--sp-7);
  }
  .section-header--center {
    align-items: center;
    text-align: center;
    max-width: 46rem;
    margin-inline: auto;
  }
  .section-header :global(p) {
    color: var(--c-ink-soft);
    font-size: var(--fs-500);
    max-width: 44rem;
  }
</style>
