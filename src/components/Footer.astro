---
import { Icon } from 'astro-icon/components';
import { footerColumns } from '../data/nav';
import { site } from '../data/site';

const year = 2026; // build-time constant; update at next rebuild
---

<footer class="footer">
  <svg class="footer__wave" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0,32 C240,64 480,0 720,20 C960,40 1200,68 1440,36 L1440,60 L0,60 Z"></path>
  </svg>
  <div class="container-wide footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label={`${site.name} home`}>
        <img src="/images/logo.webp" alt={site.name} width="170" height="54" />
      </a>
      <ul class="footer__socials">
        {
          site.socials.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.name}>
                <Icon name={s.icon} />
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    {
      footerColumns.map((col) => (
        <nav class="footer__col" aria-label={col.heading}>
          <h2 class="footer__heading">{col.heading}</h2>
          <ul>
            {col.links.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }

    <div class="footer__col footer__contact">
      <h2 class="footer__heading">Visit Us</h2>
      <address>
        <p>{site.address.full}</p>
        <ul class="footer__contact-list">
          {
            site.phones.map((p) => (
              <li>
                <Icon name="lucide:phone" />
                <a href={p.href}>{p.label}</a>
              </li>
            ))
          }
          <li>
            <Icon name="lucide:mail" />
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <Icon name="lucide:clock" />
            <span>{site.hoursSummary}</span>
          </li>
        </ul>
      </address>
      <a
        class="footer__whatsapp"
        href={site.integrations.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
      >
        <Icon name="fa6-brands:whatsapp" />
        Chat on WhatsApp
      </a>
    </div>
  </div>

  <div class="footer__bar">
    <div class="container-wide footer__bar-inner">
      <p>© {site.foundedYear}–{year} {site.name}. Made with care in Srinagar.</p>
      <a href={site.integrations.enquiry} target="_blank" rel="noopener noreferrer"
        >Enquire about a place →</a
      >
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    margin-top: var(--section-y);
    background: #241f2e;
    color: #d7d2e0;
    padding-top: var(--sp-8);
  }
  .footer__wave {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 40px;
    fill: #241f2e;
    transform: translateY(-98%);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr repeat(3, 1fr) 1.6fr;
    gap: var(--sp-6);
    padding-bottom: var(--sp-8);
  }

  .footer__logo img {
    height: 52px;
    width: auto;
  }

  .footer__socials {
    display: flex;
    gap: var(--sp-2);
    list-style: none;
    padding: 0;
    margin-top: var(--sp-4);
  }
  .footer__socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    transition:
      background var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-bounce);
  }
  .footer__socials a:hover {
    background: var(--c-primary);
    color: var(--c-primary-ink);
    transform: translateY(-3px);
  }
  .footer__socials :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
  }

  .footer__heading {
    font-size: 1.05rem;
    color: #fff;
    margin-bottom: var(--sp-3);
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .footer__col a {
    color: #c3bdcf;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer__col a:hover {
    color: var(--c-primary);
  }

  .footer__contact address {
    font-style: normal;
  }
  .footer__contact-list {
    margin-top: var(--sp-3);
  }
  .footer__contact-list li {
    display: flex;
    align-items: center;
    gap: 0.6em;
  }
  .footer__contact-list :global(svg) {
    width: 1rem;
    height: 1rem;
    color: var(--c-primary);
    flex-shrink: 0;
  }

  .footer__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    margin-top: var(--sp-4);
    background: var(--c-whatsapp);
    color: #04331a !important;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    padding: 0.6em 1.1em;
    border-radius: var(--radius-pill);
    text-decoration: none;
  }
  .footer__whatsapp :global(svg) {
    width: 1.2em;
    height: 1.2em;
  }

  .footer__bar {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: var(--sp-4);
  }
  .footer__bar-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: space-between;
    align-items: center;
    font-size: var(--fs-sm);
  }
  .footer__bar-inner a {
    color: var(--c-primary);
    text-decoration: none;
    font-weight: var(--fw-bold);
  }

  @media (max-width: 899px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand,
    .footer__contact {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 520px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
